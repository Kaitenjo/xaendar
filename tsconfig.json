{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "noEmit": true,
    "paths": {
      "@xendar/common": [
        "./@xendar/common"
      ],
      "@xendar/compiler": [
        "./@xendar/compiler"
      ],
      "@xendar/core": [
        "./@xendar/core"
      ],
      "@xendar/signals": [
        "./@xendar/signals"
      ]
    },
    "lib": [
      "ESNext",
      "dom"
    ]
  },
  "exclude": [
    "**/vite-config.ts",
    "**/vite.config.ts",
    "**/*.spec.ts",
    "dist"
  ]
}
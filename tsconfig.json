{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "dom"],
    "sourceMap": true,
    "declaration": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "noEmit": true,
    "rootDir": ".",
    "paths": {
      "@xaendar/build-tools": ["./packages/build-tools/src/public-api"],
      "@xaendar/common": ["./packages/common/src/public-api"],
      "@xaendar/core": ["./packages/core/src/public-api"],
      "@xaendar/compiler": ["./packages/compiler/src/public-api"],
      "@xaendar/signals": ["./packages/signals/src/public-api"],
      "@xaendar/types": ["./packages/types/src/public-api"]
    }
  },
  "exclude": [
    "**/vite-config.ts",
    "**/vite.config.ts",
    "**/*.spec.ts",
    "dist"
  ]
}
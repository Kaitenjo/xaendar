{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "noEmit": true,
    "paths": {
      "@xendar/common": [
        "../../dist/@xendar/common/xendar-common.es.d.ts"
      ],
      "@xendar/core": [
        "../../dist/@xendar/core/xendar-core.es.d.ts"
      ],
      "@xendar/compiler": [
        "../../dist/@xendar/compiler/xendar-compiler.es.d.ts"
      ],
      "@xendar/signals": [
        "../../dist/@xendar/signals/xendar-signals.es.d.ts"
      ]
    },
    "lib": [
      "ESNext",
      "dom"
    ]
  },
  "exclude": [
    "**/vite-config.ts",
    "**/vite.config.ts",
    "**/*.spec.ts",
    "dist"
  ]
}
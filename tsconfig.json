{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "noEmit": true,
    "paths": {
      "@xendar/common": ["./packages/common/src/public-api"],
      "@xendar/core": ["./packages/core/src/public-api"],
      "@xendar/compiler": ["./packages/compiler/src/public-api"],
      "@xendar/signals": ["./packages/signals/src/public-api"]
    },
    "lib": [
      "ESNext",
      "dom"
    ]
  },
  "exclude": [
    "**/vite-config.ts",
    "**/vite.config.ts",
    "**/*.spec.ts",
    "dist"
  ]
}
{
  "name": "xendar",
  "version": "0.2.0",
  "author": "Kaitenjo",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "build:schematics": "npm run build --prefix schematics",
    "build:schematics:watch": "npm run build:watch --prefix schematics",
    "build:projects": "npm run build-projects --prefix schematics",
    "build:src": "vite build",
    "check:dependencies": "npm run check-dependencies --prefix schematics",
    "compile:projects": "npm run compile-projects --prefix schematics",
    "deploy": "npm run build:schematics && npm run check:dependencies && npx vitest run && npm run compile:projects && npm run build:projects && npm run update-version &&npm run pack:projects && npm run publish:projects",
    "i": "npm i --omit-optional --ignore-scripts",
    "install:clean": "rimraf package-lock.json node_modules && npm run i",
    "pack:projects": "npm run pack --prefix schematics",
    "publish:projects": "npm run publish --prefix schematics",
    "start:node": "nodemon --watch src --watch packages -e ts --exec \"node --inspect-brk --import tsx/esm src/test.ts\"",
    "start:browser": "vite",
    "test:debug": "node --inspect-brk ./node_modules/.bin/vitest run signals",
    "update-version": "npm run update-version --prefix schematics",
    "xd": "node --import tsx/esm packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "depcheck": "^1.4.7",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}

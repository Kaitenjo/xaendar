{
  "name": "xendar",
  "version": "1.0.0",
  "scripts": {
    "build:schematics": "npm run build --prefix schematics",
    "build:schematics:watch": "npm run build:watch --prefix schematics",
    "build:projects": "npm run build-projects --prefix schematics",
    "check-dependencies": "npm run check-dependencies --prefix schematics",
    "i": "npm i --omit-optional --ignore-scripts",
    "install:clean": "rimraf package-lock.json node_modules && npm run i",
    "start": "nodemon --watch src --watch packages -e ts --exec \"vite build && node --enable-source-maps dist/test.es.js\""
  },
  "author": "Kaitenjo",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "depcheck": "^1.4.7",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}